{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soul-kaleidoscope.local/schemas/soul-profile.schema.json",
  "title": "Soul Kaleidoscope Profile",
  "type": "object",
  "required": ["meta", "subject", "source", "calendar", "numerology", "outputs"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["schemaVersion", "engineVersion", "generatedAt"],
      "properties": {
        "schemaVersion": { "const": "1.1.0" },
        "engineVersion": { "type": "string", "minLength": 1 },
        "generatedAt": { "type": "string", "format": "date-time" },
        "profileId": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "subject": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": ["solarBirthDate", "birthTimeStatus", "birthTime", "calculationHour", "queryDate", "lunarBirth"],
      "properties": {
        "solarBirthDate": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "birthTimeStatus": { "enum": ["known", "unknown"] },
        "birthTime": {
          "oneOf": [
            { "type": "string", "pattern": "^[0-9]{2}:[0-9]{2}$" },
            { "type": "null" }
          ]
        },
        "calculationHour": {
          "oneOf": [
            { "type": "integer", "minimum": 1, "maximum": 24 },
            { "type": "null" }
          ]
        },
        "queryDate": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "lunarBirth": {
          "type": "object",
          "required": ["year", "month", "day", "leap", "calculationMonth"],
          "properties": {
            "year": { "type": "integer" },
            "month": { "type": "integer", "minimum": 1, "maximum": 12 },
            "day": { "type": "integer", "minimum": 1, "maximum": 30 },
            "leap": { "type": "boolean" },
            "calculationMonth": { "type": "integer", "minimum": 1, "maximum": 13 }
          },
          "additionalProperties": false
        }
      },
      "allOf": [
        {
          "if": { "properties": { "birthTimeStatus": { "const": "known" } } },
          "then": {
            "properties": {
              "birthTime": { "type": "string", "pattern": "^[0-9]{2}:[0-9]{2}$" },
              "calculationHour": { "type": "integer", "minimum": 1, "maximum": 24 }
            }
          }
        },
        {
          "if": { "properties": { "birthTimeStatus": { "const": "unknown" } } },
          "then": {
            "properties": {
              "birthTime": { "type": "null" },
              "calculationHour": { "type": "null" }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "calendar": {
      "type": "object",
      "required": ["queryLunar", "solar", "lunar"],
      "properties": {
        "queryLunar": { "type": ["object", "null"] },
        "solar": { "type": "object" },
        "lunar": { "type": "object" }
      }
    },
    "numerology": {
      "type": "object",
      "required": ["solar", "lunar"],
      "properties": {
        "solar": { "$ref": "#/$defs/numerologyCalendar" },
        "lunar": { "$ref": "#/$defs/numerologyCalendar" }
      }
    },
    "outputs": {
      "type": "object",
      "required": ["report", "soulKaleidoscope"],
      "properties": {
        "report": { "type": ["object", "null"] },
        "soulKaleidoscope": { "type": ["object", "null"] }
      }
    }
  },
  "$defs": {
    "numerologyCalendar": {
      "type": "object",
      "required": ["soulStages", "primaryNumber", "flow", "horse"],
      "properties": {
        "soulStages": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "type": "object",
            "required": ["label", "source", "chain", "final", "level", "status"],
            "properties": {
              "label": { "type": "string" },
              "source": { "type": ["integer", "null"] },
              "chain": { "type": ["string", "null"] },
              "final": { "type": ["integer", "null"] },
              "level": { "type": ["string", "null"] },
              "status": { "enum": ["available", "unavailable"] },
              "reason": { "type": "string" }
            }
          }
        },
        "primaryNumber": { "type": ["integer", "null"], "minimum": 0, "maximum": 9 },
        "flow": { "type": "object" },
        "horse": { "type": "object" }
      }
    }
  }
}
