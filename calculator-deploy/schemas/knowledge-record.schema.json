{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soul-kaleidoscope.local/schemas/knowledge-record.schema.json",
  "title": "Soul Kaleidoscope Knowledge Record",
  "type": "object",
  "required": ["id", "domain", "matchKey", "reviewStatus", "version", "sourceRefs", "content"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Z]{3}-[A-Z0-9-]{3,}$" },
    "domain": {
      "type": "string",
      "enum": [
        "number-topic",
        "position",
        "day-moon",
        "horse",
        "helper",
        "soul-level",
        "annual",
        "relationship",
        "career",
        "money",
        "growth",
        "geometry",
        "prompt",
        "oil",
        "report"
      ]
    },
    "matchKey": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": ["string", "number", "integer", "boolean"]
      }
    },
    "reviewStatus": {
      "type": "string",
      "enum": ["Pending", "Candidate", "Reviewed", "Rejected", "Conflict", "Canonical"]
    },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "lastReviewedAt": { "type": ["string", "null"], "format": "date-time" },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sourceId", "sourceType", "location"],
        "additionalProperties": false,
        "properties": {
          "sourceId": { "type": "string" },
          "sourceType": { "type": "string", "enum": ["google-sheet", "google-doc", "drive-file", "manual-decision", "github"] },
          "location": { "type": "string" },
          "sheetName": { "type": ["string", "null"] },
          "row": { "type": ["integer", "null"], "minimum": 1 },
          "pageRefs": { "type": ["string", "null"] },
          "modifiedAt": { "type": ["string", "null"], "format": "date-time" }
        }
      }
    },
    "content": {
      "type": "object",
      "required": ["title", "theme", "observation", "mature", "imbalance", "action"],
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "theme": { "type": "string", "minLength": 1 },
        "observation": { "type": "string", "minLength": 1 },
        "mature": { "type": "string", "minLength": 1 },
        "imbalance": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "keywords": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "applications": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "geometry": { "type": ["string", "null"] },
        "colors": { "type": "array", "items": { "type": "string" } },
        "relationship": { "type": ["string", "null"] },
        "money": { "type": ["string", "null"] },
        "spiritual": { "type": ["string", "null"] },
        "affirmation": { "type": ["string", "null"] },
        "energyCorrespondence": { "type": ["string", "null"] },
        "bodyNotes": { "type": ["string", "null"] }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceStatus": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] },
        "conflicts": { "type": "array", "items": { "type": "string" } },
        "approvedBy": { "type": ["string", "null"] },
        "approvalRecord": { "type": ["string", "null"] }
      }
    }
  }
}
