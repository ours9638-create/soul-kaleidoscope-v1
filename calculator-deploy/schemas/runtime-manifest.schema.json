{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soul-kaleidoscope.local/schemas/runtime-manifest.schema.json",
  "title": "Soul Kaleidoscope Runtime Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "manifestId", "generatedAt", "datasets"],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "manifestId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:(?:[0-9]{2}(?:0[48]|[2468][048]|[13579][26])|(?:00|0[48]|[2468][048]|[13579][26])00)-02-29)|(?:[0-9]{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12][0-9]|3[01])|(?:0[469]|11)-(?:0[1-9]|[12][0-9]|30)|02-(?:0[1-9]|1[0-9]|2[0-8]))))T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]+)?(?:Z|[+-](?:[01][0-9]|2[0-3]):[0-5][0-9])$"
    },
    "datasets": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": {
                "const": "number-topic"
              }
            }
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": {
                "const": "position"
              }
            }
          },
          "minContains": 1,
          "maxContains": 1
        }
      ],
      "items": {
        "$ref": "#/$defs/dataset"
      }
    }
  },
  "$defs": {
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "candidateWorkflow", "published"],
      "properties": {
        "id": {
          "type": "string",
          "enum": ["number-topic", "position"]
        },
        "candidateWorkflow": {
          "$ref": "#/$defs/candidateWorkflow"
        },
        "published": {
          "$ref": "#/$defs/published"
        }
      }
    },
    "candidateWorkflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewStatus", "artifactPath", "runtimeReadable"],
      "properties": {
        "reviewStatus": {
          "enum": ["Pending", "Candidate", "Reviewed", "Rejected", "Conflict", "Canonical", "NotApplicable"]
        },
        "artifactPath": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "runtimeReadable": {
          "const": false
        }
      }
    },
    "published": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactPath", "approval", "hash"],
      "properties": {
        "artifactPath": {
          "type": "string",
          "pattern": "^data/sngl/[A-Za-z0-9._/-]+$"
        },
        "approval": {
          "$ref": "#/$defs/approval"
        },
        "hash": {
          "$ref": "#/$defs/hash"
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "baselineId", "evidencePath"],
      "properties": {
        "status": {
          "enum": ["approved", "pending", "revoked"]
        },
        "baselineId": {
          "type": "string",
          "minLength": 1
        },
        "evidencePath": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "hash": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactPath",
        "sourceKind",
        "fileCount",
        "algorithm",
        "hashValue",
        "normalization",
        "lineEndingRule",
        "generatedAt",
        "generationMethod"
      ],
      "properties": {
        "artifactPath": {
          "type": "string",
          "pattern": "^data/sngl/[A-Za-z0-9._/-]+$"
        },
        "sourceKind": {
          "const": "published-artifact"
        },
        "fileCount": {
          "const": 1
        },
        "algorithm": {
          "const": "SHA-256"
        },
        "hashValue": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "normalization": {
          "const": "none"
        },
        "lineEndingRule": {
          "const": "exact-raw-bytes-lf"
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:(?:[0-9]{2}(?:0[48]|[2468][048]|[13579][26])|(?:00|0[48]|[2468][048]|[13579][26])00)-02-29)|(?:[0-9]{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12][0-9]|3[01])|(?:0[469]|11)-(?:0[1-9]|[12][0-9]|30)|02-(?:0[1-9]|1[0-9]|2[0-8]))))T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]+)?(?:Z|[+-](?:[01][0-9]|2[0-3]):[0-5][0-9])$"
        },
        "generationMethod": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
